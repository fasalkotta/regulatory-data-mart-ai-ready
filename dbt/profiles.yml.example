regulatory_data_mart_ai_ready:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "<your_snowflake_account_identifier>"
      user: "<your_snowflake_username>"
      password: "<your_snowflake_password>"
      role: "REG_ANALYTICS_DBT_DEVELOPER"
      database: "REGULATORY_ANALYTICS"
      warehouse: "REG_ANALYTICS_WH"
      schema: "DEV_FASAL"
      threads: 4
      client_session_keep_alive: false

    prod:
      type: snowflake
      account: "<your_snowflake_account_identifier>"
      user: "<your_snowflake_username>"
      password: "<your_snowflake_password>"
      role: "REG_ANALYTICS_DBT_DEVELOPER"
      database: "REGULATORY_ANALYTICS"
      warehouse: "REG_ANALYTICS_WH"
      schema: "PROD"
      threads: 4
      client_session_keep_alive: false

